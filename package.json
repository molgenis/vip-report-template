{
  "name": "@molgenis/vip-report-template",
  "version": "8.3.3",
  "description": "Report Template for Variant Call Format (VCF) Report Generator",
  "scripts": {
    "build": "vite build",
    "build-dev": "vite build --mode dev",
    "coverage": "vitest run --coverage",
    "dev": "vite",
    "format": "prettier --write src/**/*.{json,tsx,ts}",
    "lint": "eslint src/**/*.{json,tsx,ts}",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "LGPL-3.0",
  "pnpm": {
    "overrides": {
      "chokidar": "5.0.0",
      "semver": "7.7.4"
    }
  },
  "devDependencies": {
    "@molgenis/vite-plugin-inline": "^2.0.2",
    "@types/async-lock": "^1.4.2",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.3",
    "async-lock": "^1.4.1",
    "bulma": "^1.0.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.7",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@molgenis/vip-report-api": "7.0.7",
    "@molgenis/vip-report-vcf": "^4.0.8",
    "@solidjs/router": "^0.16.1",
    "ajv": "^8.18.0",
    "base64-js": "^1.5.1",
    "igv": "^3.8.0",
    "solid-js": "^1.9.12",
    "sql.js": "^1.13.0"
  },
  "lint-staged": {
    "src/**/*.{tsx,ts}": [
      "eslint",
      "prettier --write"
    ]
  },
  "bugs": {
    "url": "https://github.com/molgenis/vip-report-template/issues"
  },
  "homepage": "https://github.com/molgenis/vip-report-template#readme",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/molgenis/vip-report-template.git"
  },
  "engines": {
    "node": "24",
    "pnpm": "10"
  }
}
